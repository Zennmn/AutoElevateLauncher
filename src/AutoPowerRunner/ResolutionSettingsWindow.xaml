<Window x:Class="AutoPowerRunner.ResolutionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快速分辨率切换"
        Icon="{StaticResource AppShieldLogoImage}"
        Width="640"
        Height="500"
        MinWidth="600"
        MinHeight="470"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FB"
        FontFamily="Microsoft YaHei UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <SolidColorBrush x:Key="Brand" Color="#2563EB" />
        <SolidColorBrush x:Key="TextPrimary" Color="#172033" />
        <SolidColorBrush x:Key="TextSecondary" Color="#667085" />
        <SolidColorBrush x:Key="Border" Color="#E4E9F0" />
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckChrome"
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#FFFFFF"
                                    BorderBrush="#B9C7DA"
                                    BorderThickness="1"
                                    CornerRadius="5">
                                <Path x:Name="CheckMark"
                                      Width="10"
                                      Height="7"
                                      Data="M0,3.5 L3.5,7 L10,0"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource Brand}" />
                                <Setter TargetName="CheckChrome" Property="Background" Value="#F5F8FF" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource Brand}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckChrome" Property="Background" Value="{StaticResource Brand}" />
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource Brand}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HotkeyCaptureField" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#9FB6D8" />
                    <Setter Property="Background" Value="#F5F8FF" />
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Brand}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Background" Value="#EEF4FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="FieldChrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FieldChrome" Property="BorderBrush" Value="{StaticResource Brand}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FieldChrome" Property="BorderBrush" Value="#B9C7DA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource Brand}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brand}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FB">
        <Border Margin="20" Background="#FFFFFF" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,16,24,14">
                    <TextBlock Text="快速分辨率切换" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Margin="0,4,0,0" Text="使用全局快捷键在两组主显示器分辨率之间切换" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
                <Border Grid.Row="1" Background="{StaticResource Border}" />

                <Grid Grid.Row="2" Margin="24,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="118" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="启用快捷切换" />
                    <CheckBox x:Name="EnabledBox" Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernCheckBox}" Content="在软件运行期间注册全局快捷键" VerticalAlignment="Center" />

                    <TextBlock Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource FieldLabel}" Text="第一组分辨率" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" Orientation="Horizontal">
                        <TextBox x:Name="FirstWidthBox" Width="112" Style="{StaticResource Field}" />
                        <TextBlock Margin="10,0" Text="×" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" />
                        <TextBox x:Name="FirstHeightBox" Width="112" Style="{StaticResource Field}" />
                    </StackPanel>

                    <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabel}" Text="第二组分辨率" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Orientation="Horizontal">
                        <TextBox x:Name="SecondWidthBox" Width="112" Style="{StaticResource Field}" />
                        <TextBlock Margin="10,0" Text="×" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" />
                        <TextBox x:Name="SecondHeightBox" Width="112" Style="{StaticResource Field}" />
                    </StackPanel>

                    <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource FieldLabel}" Text="全局快捷键" />
                    <Border x:Name="HotkeyField"
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="0,12,0,0"
                            Height="36"
                            Padding="10,0"
                            Style="{StaticResource HotkeyCaptureField}"
                            PreviewKeyDown="HotkeyField_PreviewKeyDown"
                            MouseLeftButtonDown="HotkeyField_MouseLeftButtonDown"
                            GotKeyboardFocus="HotkeyField_GotKeyboardFocus"
                            LostKeyboardFocus="HotkeyField_LostKeyboardFocus"
                            Focusable="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="HotkeyText" VerticalAlignment="Center" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="HotkeyCaptureHint"
                                       Grid.Column="1"
                                       Margin="12,0,0,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Text="请按下新快捷键"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brand}"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="4" Grid.ColumnSpan="2" Margin="0,18,0,0" Padding="12" Background="#F5F7FA" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8">
                        <TextBlock Text="点击快捷键框后直接按下新组合键。若当前分辨率不属于两组配置，首次触发会切换到第一组。" TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                    </Border>
                </Grid>

                <Border Grid.Row="3" Padding="24,12" Background="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button MinWidth="82" Margin="0,0,8,0" Style="{StaticResource BaseButton}" IsCancel="True" Content="取消" />
                        <Button MinWidth="90" Style="{StaticResource PrimaryButton}" Click="Save_Click" Content="保存设置" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
